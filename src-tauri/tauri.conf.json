{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mykdown",
  "version": "1.0.0-alpha.3",
  "identifier": "dev.leandro.mykdown",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mykdown",
        "width": 1220,
        "height": 780,
        "minWidth": 720,
        "minHeight": 500,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 18 },
        "backgroundColor": "#20242b"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Documento Markdown",
        "role": "Editor",
        "rank": "Default",
        "contentTypes": ["net.daringfireball.markdown"]
      }
    ],
    "category": "Productivity",
    "shortDescription": "Editor Markdown pessoal para macOS",
    "longDescription": "Mykdown abre e edita arquivos Markdown diretamente no filesystem do macOS.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-"
    }
  }
}
